# Server
PORT=4000
NODE_ENV=development

# CORS — the frontend origin allowed to call the API
CLIENT_ORIGIN=http://localhost:5173

# Public URL of the SPA (used to build links inside emails / the customer portal)
APP_URL=http://localhost:5173

# Auth — use long, random values in production
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=change-me-refresh-secret
REFRESH_TOKEN_EXPIRES_IN=7d
REFRESH_TOKEN_TTL_DAYS=7
RESET_TOKEN_TTL_MINUTES=60

# Customer portal links (days a generated link stays valid; 0 = never expires)
PORTAL_TOKEN_TTL_DAYS=90

# Email delivery
# Leave SMTP_HOST blank to use the credential-free dev/preview transport
# (messages are still logged to the EmailLog table). Set SMTP_* to send for real.
MAIL_FROM="SmartInvoice Pro <no-reply@smartinvoice.pro>"
EMAIL_PREVIEW=json            # json | ethereal
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Database
DATABASE_URL="postgresql://postgres:1999@localhost:5432/smartinvoice?schema=public"
