{
  "name": "smartinvoice-backend",
  "version": "0.1.0",
  "description": "SmartInvoice Pro REST API (Node.js + Express)",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test": "node --test test/*.test.js",
    "test:integration": "for f in *-test.mjs; do NODE_ENV=test node \"$f\" || exit 1; done",
    "lint": "eslint src --ext js",
    "prisma:generate": "prisma generate --schema ../database/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.16.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^9.0.1",
    "pdfkit": "^0.19.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "nodemon": "^3.1.4",
    "prisma": "^5.16.0"
  }
}
